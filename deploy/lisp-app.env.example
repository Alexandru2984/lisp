# Environment for the Lisp Control Center service.
#
# Copy this file to a location OUTSIDE the git repository (the systemd unit
# loads it via EnvironmentFile), then fill in real values and lock it down:
#
#     sudo install -d -m 750 /etc/lisp-app
#     sudo cp deploy/lisp-app.env.example /etc/lisp-app/lisp-app.env
#     sudoedit /etc/lisp-app/lisp-app.env
#     sudo chmod 600 /etc/lisp-app/lisp-app.env
#
# Generate strong secrets:
#     LISP_AUTH_PASS:      openssl rand -base64 24
#     LISP_SESSION_SECRET: openssl rand -hex 32
#
# NEVER commit a filled-in copy of this file.

# --- Required secrets (the service refuses to start without them) ---
LISP_AUTH_USER=admin
LISP_AUTH_PASS=change-me-min-12-chars
LISP_SESSION_SECRET=change-me-with-openssl-rand-hex-32-at-least-32-chars

# --- Optional tunables (defaults shown) ---
# LISP_BIND_ADDRESS=127.0.0.1
# LISP_PORT=8093
# LISP_EVAL_TIMEOUT=3
# LISP_DATA_FILE=/home/micu/lisp/lisp-app/data/functions.lisp
# LISP_LOG_DIR=/home/micu/lisp/lisp-app/logs
