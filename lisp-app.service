[Unit]
Description=Common Lisp Web Service
After=network.target

[Service]
Type=simple
User=micu
WorkingDirectory=/home/micu/commonLisp/lisp-app
ExecStart=/usr/bin/sbcl --non-interactive --load /home/micu/commonLisp/lisp-app/src/app.lisp
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
